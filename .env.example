# Copy this file to .env and fill in your values.

# Required: OpenAI API key for policy generation.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: model used for code-as-policy generation.
OPENAI_MODEL=gpt-4.1-mini

# Optional: ROS topic where speech-to-text node publishes text.
VOICE_TOPIC=/voice/text

# Optional: override default system prompt.
# POLICY_SYSTEM_PROMPT=You translate voice commands into Python policies...
